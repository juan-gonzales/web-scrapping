NODE_ENV=development
PORT=8000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=utp_scraper
DB_USER=postgres
DB_PASSWORD=postgres

# Playwright / timeouts
SCRAPER_HEADLESS=true
REQUEST_TIMEOUT_MS=30000

# Targets
MEL1_BASE_URL=https://...
MEL2_BASE_URL=https://...

# Credenciales (si la app origen lo requiere)
MEL1_USERNAME=...
MEL1_PASSWORD=...
MEL2_USERNAME=...
MEL2_PASSWORD=...

# Keycloak (MEL2)
KEYCLOAK_BASE_URL=https://...
KEYCLOAK_REALM=...
KEYCLOAK_CLIENT_ID=...
KEYCLOAK_USERNAME=...
KEYCLOAK_PASSWORD=...
